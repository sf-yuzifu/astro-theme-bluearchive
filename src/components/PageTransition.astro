---
// 页面切换动画组件 - 实现类似Vue的fade过渡效果
---

<script>
  // @ts-ignore
  import NProgress from "nprogress";

  // 配置 NProgress
  NProgress.configure({
    showSpinner: false,
    speed: 200,
    trickleSpeed: 200,
  });

  // 获取当前页面类型
  function getPageType(pathname: string) {
    const path = pathname.replace(/\/$/, "") || "/";
    if (path === "/") return "home";
    if (path === "/tags" || path.startsWith("/tags/")) return "tags";
    if (path.startsWith("/blog/")) return "post";
    return "other";
  }

  // 渐隐 - 在切换前执行
  function fadeOutContent(fromType: string, toType: string) {
    const mainContent = document.getElementById("main-content");
    const bannerContent = document.getElementById("banner-content");

    if (mainContent) {
      mainContent.style.transition = ``;
      mainContent.style.opacity = "0";
    }

    // Banner内容区域也需要动画（除非是Tags页面间切换）
    if (bannerContent && !(fromType === "tags" && toType === "tags")) {
      bannerContent.style.transition = ``;
      bannerContent.style.opacity = "0";
    }
  }

  // 渐显 - 在切换后执行
  function fadeInContent(fromType: string | null, toType: string | null) {
    const mainContent = document.getElementById("main-content");
    const bannerContent = document.getElementById("banner-content");

    if (mainContent) {
      // 先设置为0（无动画），确保从隐藏状态开始
      mainContent.style.transition = "none";
      mainContent.style.opacity = "0";

      // 强制重绘
      void mainContent.offsetHeight;

      // 恢复transition并渐显
      mainContent.style.transition = ``;
      mainContent.style.opacity = "1";
    }

    // Banner内容区域也需要动画（除非是Tags页面间切换）
    if (bannerContent && !(fromType === "tags" && toType === "tags")) {
      // 先设置为0（无动画），确保从隐藏状态开始
      bannerContent.style.transition = "none";
      bannerContent.style.opacity = "0";

      // 强制重绘
      void bannerContent.offsetHeight;

      // 恢复transition并渐显
      bannerContent.style.transition = ``;
      bannerContent.style.opacity = "1";
    }
  }

  // 在页面切换前执行 - 开始渐隐动画和NProgress
  document.addEventListener("astro:before-preparation", (event) => {
    const fromType = getPageType(window.location.pathname);
    const toType = getPageType((event as any).to?.pathname || "");

    // 保存页面类型
    sessionStorage.setItem("fromPageType", fromType);
    sessionStorage.setItem("toPageType", toType);

    // 开始NProgress
    NProgress.start();

    // 开始渐隐动画
    fadeOutContent(fromType, toType);
  });

  // 在页面切换后执行 - 开始渐显动画和完成NProgress
  document.addEventListener("astro:after-swap", (event) => {
    const fromType = sessionStorage.getItem("fromPageType");
    const toType = sessionStorage.getItem("toPageType");

    // 完成NProgress
    NProgress.done();

    // 开始渐显动画
    fadeInContent(fromType, toType);
  });

  // 相同路由守卫
  document.addEventListener(
    "click",
    (event) => {
      if (event.defaultPrevented) return;
      if (event.button !== 0) return;
      if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey)
        return;

      const anchor = (event.target as HTMLElement).closest("a[href]");
      if (!anchor) return;
      // @ts-ignore
      if (anchor.target && anchor.target !== "_self") return;
      if (anchor.hasAttribute("download")) return;
      // @ts-ignore
      const targetUrl = new URL(anchor.href, window.location.origin);
      if (targetUrl.origin !== window.location.origin) return;

      const normalizePath = (path: string) => path?.replace(/\/$/, "") || "/";
      const currentPath = normalizePath(window.location.pathname);
      const targetPath = normalizePath(targetUrl.pathname);

      const samePath = currentPath === targetPath;
      const sameSearch = window.location.search === targetUrl.search;
      const hasHashJump =
        targetUrl.hash && targetUrl.hash !== window.location.hash;

      if (samePath && sameSearch && !hasHashJump) {
        event.preventDefault();
      }
    },
    true,
  );
</script>

<style is:global>
  /* 页面切换时的基础样式 */
  #main-content,
  #banner-content {
    opacity: 1;
    transition: opacity 500ms ease-in-out;
  }

  /* 确保持久化元素不参与默认的view transition */
  [transition-persist] {
    view-transition-name: none !important;
  }

  /* 禁用默认的view transition动画 */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }

  /* 减少动画偏好支持 */
  @media (prefers-reduced-motion: reduce) {
    #main-content,
    #banner-content {
      transition: none;
    }
  }

  /* NProgress 样式自定义 */
  #nprogress {
    pointer-events: none;
  }

  #nprogress .bar {
    background: var(--color-blue, #328cfa);
    position: fixed;
    z-index: 1031;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
  }

  /* 进度条右侧的闪光效果 */
  #nprogress .peg {
    display: block;
    position: absolute;
    right: 0px;
    width: 100px;
    height: 100%;
    box-shadow:
      0 0 10px var(--color-blue, #328cfa),
      0 0 5px var(--color-blue, #328cfa);
    opacity: 1;
    transform: rotate(3deg) translate(0px, -4px);
  }

  /* 移除默认的spinner */
  #nprogress .spinner {
    display: none;
  }
</style>
