---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import { SPONSOR_ENABLE, SPONSOR_TITLE, SPONSOR_METHODS } from "../consts";

interface Props {
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
  enableDonation?: boolean;
  enableNavigation?: boolean;
}

const {
  prevPost,
  nextPost,
  enableDonation = SPONSOR_ENABLE,
  enableNavigation = true,
} = Astro.props;

// 从配置文件读取捐赠配置
const sponsorTitle = SPONSOR_TITLE;
const sponsorMethods = SPONSOR_METHODS;
---

{
  enableDonation && sponsorMethods.length > 0 && (
    <section class="donation-section">
      <div class="donation-container">
        <h3 class="donation-title">{sponsorTitle}</h3>
        <div class="donation-buttons">
          {sponsorMethods.map((method) =>
            method.url ? (
              <a
                href={method.url}
                target="_blank"
                rel="noopener noreferrer"
                class="donation-btn"
                style={`background: ${method.color}`}
              >
                <Icon name={method.icon} class="donation-icon" />
                <span>{method.name}</span>
              </a>
            ) : (
              <div class="donation-item">
                <button
                  class="donation-btn"
                  style={`background: ${method.color}`}
                >
                  <Icon name={method.icon} class="donation-icon" />
                  <span>{method.name}</span>
                </button>
                {method.image && (
                  <div class="donation-qr">
                    <img src={method.image} alt={`${method.name}`} />
                  </div>
                )}
              </div>
            ),
          )}
        </div>
      </div>
    </section>
  )
}

{
  enableNavigation && (
    <nav class="post-navigation">
      <div class="nav-container">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}/`} class="nav-link prev">
            <span class="nav-label">← 上一篇</span>
            <span class="nav-title">{prevPost.data.title}</span>
          </a>
        ) : (
          <div class="nav-link prev disabled">
            <span class="nav-label">← 上一篇</span>
            <span class="nav-title">没有了</span>
          </div>
        )}

        {nextPost ? (
          <a href={`/blog/${nextPost.id}/`} class="nav-link next">
            <span class="nav-label">下一篇 →</span>
            <span class="nav-title">{nextPost.data.title}</span>
          </a>
        ) : (
          <div class="nav-link next disabled">
            <span class="nav-label">下一篇 →</span>
            <span class="nav-title">没有了</span>
          </div>
        )}
      </div>
    </nav>
  )
}

<style lang="less">
  /**
   * Donation Section
   * -------------------------------------------------------------------------- */
  .donation-section {
    box-sizing: border-box;
    margin: 32px auto 0;
    max-width: 1200px;
  }

  .donation-container {
    padding: 24px;
    border-radius: 32px;
    border: 2px solid var(--foreground-color);
    background: var(--foreground-color);
    box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.8);
    text-align: center;
    transition:
      border-color 0.5s,
      background 0.5s,
      box-shadow 0.5s;
  }

  .donation-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--font-color-grey);
    margin: 0 0 16px;
    transition: color 0.5s;
  }

  .donation-buttons {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .donation-item {
    position: relative;
  }

  .donation-btn {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 8px;
    border: none;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    color: #fff !important;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;

    &:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }
  }

  .donation-icon {
    width: 18px;
    height: 18px;
    margin-right: 6px;
  }

  .donation-qr {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) scale(0.95);
    opacity: 0;
    visibility: hidden;
    padding: 12px;
    border-radius: 12px;
    background: var(--foreground-color);
    border: 2px solid var(--foreground-color);
    box-shadow: 0px 4px 16px rgba(0, 0, 0, 0.15);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s ease;
    z-index: 100;

    img {
      width: 140px;
      height: 140px;
      border-radius: 8px;
      display: block;
    }

    &::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: var(--foreground-color);
    }
  }

  .donation-item:hover .donation-qr {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) scale(1);
  }

  /**
   * Post Navigation
   * -------------------------------------------------------------------------- */
  .post-navigation {
    box-sizing: border-box;
    margin: 32px auto 0;
    max-width: 1200px;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    padding: 16px 20px;
    border-radius: 32px;
    border: 2px solid var(--foreground-color);
    background: var(--foreground-color);
    box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.8);
    text-decoration: none;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.5s,
      background 0.5s;
    flex: 1;
    max-width: 50%;

    &:hover:not(.disabled) {
      transform: translateY(-2px);
      box-shadow: 0px 4px 12px rgb(var(--blue-shadow-color), 0.5);
    }

    &.prev {
      align-items: flex-start;
      text-align: left;
    }

    &.next {
      align-items: flex-end;
      text-align: right;
      margin-left: auto;
    }

    &.disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
  }

  .nav-label {
    font-size: 14px;
    color: var(--color-blue);
    font-weight: 500;
    margin-bottom: 4px;
    transition: color 0.5s;
  }

  .nav-title {
    font-size: 16px;
    color: var(--font-color-grey);
    font-weight: 600;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    transition: color 0.5s;
  }

  @media (max-width: 768px) {
    .donation-section,
    .post-navigation {
      padding: 0 24px;
    }

    .donation-container {
      padding: 20px;
    }

    .donation-title {
      font-size: 16px;
    }

    .donation-btn {
      padding: 8px 20px;
      font-size: 13px;
    }

    .donation-qr {
      img {
        width: 120px;
        height: 120px;
      }
    }

    .nav-link {
      padding: 12px 16px;
    }

    .nav-label {
      font-size: 12px;
    }

    .nav-title {
      font-size: 14px;
    }
  }
</style>
