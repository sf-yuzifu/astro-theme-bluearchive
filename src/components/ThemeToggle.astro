---
interface Props {
  isPost?: boolean;
}

const { isPost = false } = Astro.props;
---

<div class="theme-select">
  <span class="label">主题</span>
  <div class="select-wrapper">
    <select id="theme-select">
      <option value="light">Arona</option>
      <option value="dark">Plana</option>
      <option value="system">System</option>
    </select>
    <span class="select-arrow">▼</span>
  </div>
</div>

<script>
  const themeSelect = document.getElementById(
    "theme-select",
  ) as HTMLSelectElement;
  let darkModeMediaQuery: MediaQueryList;
  let handleSystemThemeChange: (
    e: MediaQueryListEvent | MediaQueryList,
  ) => void;

  function applyTheme(theme: string) {
    let effectiveTheme = theme;
    if (theme === "system") {
      effectiveTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }
    document.documentElement.setAttribute("theme", effectiveTheme);
  }

  function changeTheme() {
    const selectedTheme = themeSelect.value;
    localStorage.setItem("theme", selectedTheme);

    if (selectedTheme === "system") {
      handleSystemThemeChange(darkModeMediaQuery);
      darkModeMediaQuery.addEventListener("change", handleSystemThemeChange);
    } else {
      darkModeMediaQuery.removeEventListener("change", handleSystemThemeChange);
    }

    applyTheme(selectedTheme);
  }

  function init() {
    // 读取主题设置
    const storedTheme = localStorage.getItem("theme") || "system";
    themeSelect.value = storedTheme;

    // 定义系统主题变化处理函数
    darkModeMediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
    handleSystemThemeChange = (e: MediaQueryListEvent | MediaQueryList) => {
      if (themeSelect.value === "system") {
        const theme = e.matches ? "dark" : "light";
        document.documentElement.setAttribute("theme", theme);
      }
    };

    // 如果是system模式,启动监听
    if (storedTheme === "system") {
      handleSystemThemeChange(darkModeMediaQuery);
      darkModeMediaQuery.addEventListener("change", handleSystemThemeChange);
    }

    applyTheme(storedTheme);

    // 绑定事件
    themeSelect?.addEventListener("change", changeTheme);
  }

  init();

  // 路由切换后重新初始化
  document.addEventListener("astro:after-swap", () => {
    const newSelect = document.getElementById(
      "theme-select",
    ) as HTMLSelectElement;
    if (newSelect) {
      const storedTheme = localStorage.getItem("theme") || "system";
      newSelect.value = storedTheme;
      newSelect.addEventListener("change", changeTheme);
    }
  });
</script>

<style lang="less">
  .theme-select {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: rgba(var(--blue-shadow-color), 0.05);
    border-radius: 12px;
    width: 100%;

    .label {
      font-size: 15px;
      color: var(--font-color-grey);
      font-weight: bold;
    }

    .select-wrapper {
      position: relative;
      width: 90px;
      align-items: center;
      display: flex;
      margin-left: 10px;

      .select-arrow {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--font-color-grey);
        font-size: 12px;
        pointer-events: none;
        opacity: 0.6;
      }
    }

    select {
      width: 100%;
      padding: 6px 28px 6px 10px;
      font-size: 14px;
      font-weight: bold;
      border-radius: 10px;
      border: 1px solid rgba(var(--blue-shadow-color), 0.15);
      background: var(--foreground-color);
      color: var(--font-color-grey);
      cursor: pointer;
      appearance: none;
      transition: all 0.3s ease;

      &:hover {
        border-color: rgba(var(--blue-shadow-color), 0.3);
        background: rgba(var(--blue-shadow-color), 0.03);
      }

      &:focus {
        outline: none;
        border-color: rgba(var(--blue-shadow-color), 0.4);
        box-shadow: 0 0 0 2px rgba(var(--blue-shadow-color), 0.1);
      }

      option {
        padding: 8px;
        background: var(--foreground-color);

        &:hover {
          background: rgba(var(--blue-shadow-color), 0.1);
        }
      }
    }
  }
</style>
