---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { Icon } from "astro-icon/components";

type Props = CollectionEntry<"blog">["data"] & {
  minutesRead?: string;
  wordCount?: number;
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  minutesRead,
  wordCount,
  prevPost,
  nextPost,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  isPost={true}
  coverImage={heroImage}
>
  <!-- Banner内容 - 文章标题信息 -->
  <div slot="banner-content" class="post-banner">
    <h1 class="title">{title}</h1>
    <span class="status">
      发布于 <FormattedDate date={pubDate} />
      {
        updatedDate && (
          <span>
            {" "}
            | 更新于 <FormattedDate date={updatedDate} />
          </span>
        )
      }
      {wordCount && <span> | 约 {wordCount} 字</span>}
      {minutesRead && <span> | {minutesRead}</span>}
    </span>
  </div>

  <!-- 主内容 - 文章内容 -->
  <article class="view-box">
    <div class="content">
      <slot />
    </div>
  </article>

  <!-- 捐赠区域 -->
  <section class="donation-section">
    <div class="donation-container">
      <h3 class="donation-title">喜欢这篇文章？打赏一下作者吧</h3>
      <div class="donation-buttons">
        <!-- 微信捐赠 -->
        <div class="donation-item">
          <button class="donation-btn wechat">
            <Icon name="ph:wechat-logo-bold" class="donation-icon" />
            <span>微信</span>
          </button>
          <div class="donation-qr">
            <img src="/images/donate-wechat.png" alt="微信捐赠二维码" />
          </div>
        </div>

        <!-- 支付宝捐赠 -->
        <div class="donation-item">
          <button class="donation-btn alipay">
            <Icon name="ph:wallet-bold" class="donation-icon" />
            <span>支付宝</span>
          </button>
          <div class="donation-qr">
            <img src="/images/donate-alipay.png" alt="支付宝捐赠二维码" />
          </div>
        </div>

        <!-- 爱发电链接 -->
        <a
          href="https://afdian.net/"
          target="_blank"
          rel="noopener noreferrer"
          class="donation-btn afdian"
        >
          <Icon name="ph:lightning-bold" class="donation-icon" />
          <span>爱发电</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 上一章/下一章导航 -->
  <nav class="post-navigation">
    <div class="nav-container">
      {
        prevPost ? (
          <a href={`/blog/${prevPost.id}/`} class="nav-link prev">
            <span class="nav-label">← 上一篇</span>
            <span class="nav-title">{prevPost.data.title}</span>
          </a>
        ) : (
          <div class="nav-link prev disabled">
            <span class="nav-label">← 上一篇</span>
            <span class="nav-title">没有了</span>
          </div>
        )
      }

      {
        nextPost ? (
          <a href={`/blog/${nextPost.id}/`} class="nav-link next">
            <span class="nav-label">下一篇 →</span>
            <span class="nav-title">{nextPost.data.title}</span>
          </a>
        ) : (
          <div class="nav-link next disabled">
            <span class="nav-label">下一篇 →</span>
            <span class="nav-title">没有了</span>
          </div>
        )
      }
    </div>
  </nav>
</BaseLayout>

<style lang="less" is:global>
  .post-banner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: var(--post-InnerBanner-color);
    text-shadow: 0 0 5px rgba(0, 0, 0, 0.8);
    z-index: 100;
    transition: color 0.5s;

    .title {
      font-size: max(64px, 4.5vw);
      margin-bottom: 50px;
      text-align: center;
      margin-top: 0;
      color: var(--post-InnerBanner-color);
      transition: color 0.5s;
    }

    .status {
      font-size: max(20px, 1vw);
      font-weight: bold;
      color: var(--post-InnerBanner-color);
      transition: color 0.5s;
    }

    @media (max-width: 768px) {
      .title {
        font-size: 5vh;
      }
      .status {
        font-size: 1.5vh;
      }
    }
  }

  .view-box {
    box-sizing: border-box;
    margin: 0 auto;
    max-width: 1200px;
    position: relative;
    padding: 36px;
    border-radius: 32px;
    border: solid 2px var(--foreground-color);
    background: var(--foreground-color);
    box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.8);
    transition:
      opacity 0.5s ease-out,
      transform 1s cubic-bezier(0.61, 0.15, 0.26, 1),
      border 0.5s,
      background 0.5s,
      box-shadow 0.5s;
  }

  .content {
    background-image:
      linear-gradient(90deg, rgba(159, 219, 252, 0.15) 3%, transparent 0),
      linear-gradient(1turn, rgba(159, 219, 252, 0.15) 3%, transparent 0);
    background-size: 20px 20px;
    background-position: 50%;
    html[theme="dark"] & {
      background-image:
        linear-gradient(90deg, rgba(207, 198, 254, 0.08) 3%, transparent 0),
        linear-gradient(1turn, rgba(207, 198, 254, 0.08) 3%, transparent 0);
    }

    /**
     * Paragraph and inline elements
     * -------------------------------------------------------------------------- */

    p,
    summary {
      margin: 16px 0;
    }

    p {
      line-height: 28px;
      color: var(--font-color-grey);
      transition: color 0.5s;
    }

    blockquote {
      margin: 16px 0;
      border-left: 3px solid #5cd3ff;
      padding-left: 16px;
      background-color: #5cd4ff25;
      border-radius: 8px;
      html[theme="dark"] & {
        background-color: rgba(157, 124, 216, 0.1);
        border-left: 3px solid #9d7cd8;
      }
    }

    blockquote > p {
      margin: 0;
      font-size: 16px;
    }

    a {
      font-weight: 500;
      color: var(--color-blue);
      text-decoration: underline;
      text-underline-offset: 2px;
      transition:
        color 0.25s,
        opacity 0.25s;
    }

    strong {
      font-weight: 600;
      color: var(--font-color-grey);
      transition: color 0.5s;
    }

    code {
      font-family: "JetBrains Mono", sans-serif;
      line-height: 0;
      border-radius: 3px;
      background-color: rgba(0, 0, 0, 0.05);
      padding: 2px 6px;
      color: var(--font-color-grey);
      transition:
        color 0.5s,
        background-color 0.5s;
      html[theme="dark"] & {
        background-color: rgba(255, 255, 255, 0.1);
      }
    }

    /**
     * Code Block
     * -------------------------------------------------------------------------- */

    pre {
      position: relative;
      background-color: #efefef;
      border: 1px solid var(--foreground-color);
      border-radius: 16px;
      box-shadow: 0px 0px 5px #c1c1c1;
      overflow: hidden;
      padding: 16px;
      margin: 16px 0;
      transition:
        background-color 0.5s,
        border-color 0.5s,
        box-shadow 0.5s;

      html[theme="dark"] & {
        background-color: #1f1f2c;
        border: 1px solid #383852;
        box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.3);
      }

      code {
        background-color: transparent;
        padding: 0;
        font-family: "JetBrains Mono", sans-serif;
        line-height: 1.6;
        color: var(--font-color-grey);

        html[theme="dark"] & {
          background-color: transparent;
        }
      }
    }

    /**
     * Headings
     * -------------------------------------------------------------------------- */

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      position: relative;
      font-weight: 600;
      outline: none;
      color: var(--font-color-grey);
      transition: color 0.5s;
    }

    h1 {
      letter-spacing: -0.02em;
      line-height: 40px;
      font-size: 28px;
    }

    h2 {
      margin: 48px 0 16px;
      border-top: 2px solid #ced4da;
      padding-top: 24px;
      letter-spacing: -0.02em;
      line-height: 32px;
      font-size: 24px;
      html[theme="dark"] & {
        border-top: 2px solid rgba(157, 124, 216, 0.3);
      }
    }

    h3 {
      margin: 32px 0 0;
      letter-spacing: -0.01em;
      line-height: 28px;
      font-size: 20px;
    }

    h4,
    h5,
    h6 {
      margin: 0;
      line-height: 24px;
      font-size: 16px;
    }

    /**
     * Decorational elements
     * -------------------------------------------------------------------------- */
    hr {
      border: 0;
      border-top: 2px dashed #ced4da;
      html[theme="dark"] & {
        border-top: 2px dashed rgba(157, 124, 216, 0.3);
      }
    }

    /**
     * Lists
     * -------------------------------------------------------------------------- */

    ul,
    ol {
      padding-left: 1.25rem;
      margin: 16px 0;
      color: var(--font-color-grey);
      transition: color 0.5s;
    }

    ul {
      list-style: disc;
    }

    ol {
      list-style: decimal;
    }

    li + li {
      margin-top: 8px;
    }

    li > ol,
    li > ul {
      margin: 8px 0 0;
    }

    /**
     * Table
     * -------------------------------------------------------------------------- */

    table {
      width: 100%;
      border-collapse: collapse;
      border: 2px solid #cad4d5;
      html[theme="dark"] & {
        border: 2px solid #383852;
      }
    }

    th,
    td {
      padding: 10px;
      text-align: center;
      border-bottom: 2px solid #cad4d5;
      transition:
        background-color 0.5s,
        color 0.5s,
        border-color 0.5s;
    }

    th {
      background-color: #e7f6fa;
      color: var(--btn-hover);
      html[theme="dark"] & {
        background-color: rgba(157, 124, 216, 0.1);
        color: #e0e0e6;
        border-bottom: 2px solid #383852;
      }
    }

    th:nth-child(odd) {
      background-color: #e0f0f2;
      html[theme="dark"] & {
        background-color: rgba(157, 124, 216, 0.15);
      }
    }

    td {
      background-color: #f7f7f6;
      color: #3c3e41;
      html[theme="dark"] & {
        background-color: rgba(31, 31, 44, 0.6);
        color: #c8c8dc;
        border-bottom: 2px solid #383852;
      }
    }

    td:nth-child(odd) {
      background-color: #ececeb;
      html[theme="dark"] & {
        background-color: rgba(31, 31, 44, 0.8);
      }
    }

    /**
     * Images
     * -------------------------------------------------------------------------- */
    img {
      max-width: 100%;
      border-radius: 8px;
    }

    /**
     * Custom Block
     * -------------------------------------------------------------------------- */

    .custom-block {
      transition:
        background-color 0.5s,
        border-color 0.5s,
        color 0.5s;

      &.tip,
      &.info,
      &.warning,
      &.danger {
        margin: 1rem 0;
        border-left: 0.35rem solid;
        padding: 0.1rem 1.5rem;
        overflow-x: auto;
        border-radius: 16px;
      }

      &.tip {
        background-color: #f1f6fa;
        border-color: #57b6f6;
        color: #005e86;

        html[theme="dark"] & {
          background-color: rgba(158, 124, 216, 0.18);
          border-color: #9e7cd8ae;
          color: #e0e0e6;
        }
      }

      &.info {
        background-color: #f3f5f7;
        border-color: var(--font-color-grey);

        html[theme="dark"] & {
          background-color: rgba(108, 182, 255, 0.161);
          border-color: #6cb6ffcf;
          color: #e0e0e6;

          .custom-block-title {
            color: #89c4ff;
          }
        }
      }

      &.warning {
        border-color: #e7c000;
        color: #6b5900;
        background-color: #fff7d0;

        html[theme="dark"] & {
          background-color: rgba(231, 192, 0, 0.1);
          color: #f0d87d;

          .custom-block-title {
            color: #e7c000;
          }
        }
      }

      &.danger {
        border-color: #d58d86;
        color: #4d0000;
        background-color: #ffe6e6;

        html[theme="dark"] & {
          background-color: rgba(213, 141, 134, 0.1);
          color: #ffc4c0;

          .custom-block-title {
            color: #ff9b93;
          }
        }
      }

      &.details {
        summary {
          font-weight: bold;
          cursor: pointer;
        }
        margin: 1rem 0;
        padding: 1rem;
        background-color: rgba(var(--blue-shadow-color), 0.05);
        border-radius: 16px;
        html[theme="dark"] & {
          background-color: rgba(157, 124, 216, 0.1);
        }
      }
    }
  }

  @media (max-width: 768px) {
    .view-box {
      padding: 24px;
      border-radius: 32px;
    }
  }

  @media (min-width: 768px) {
    .content {
      h1 {
        letter-spacing: -0.02em;
        line-height: 40px;
        font-size: 32px;
      }
    }
  }
</style>

<style lang="less">
  /**
   * Post Navigation
   * -------------------------------------------------------------------------- */
  .post-navigation {
    box-sizing: border-box;
    margin: 32px auto 0;
    max-width: 1200px;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    padding: 16px 20px;
    border-radius: 32px;
    border: 2px solid var(--foreground-color);
    background: var(--foreground-color);
    box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.8);
    text-decoration: none;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.5s,
      background 0.5s;
    flex: 1;
    max-width: 50%;

    &:hover:not(.disabled) {
      transform: translateY(-2px);
      box-shadow: 0px 4px 12px rgb(var(--blue-shadow-color), 0.5);
    }

    &.prev {
      align-items: flex-start;
      text-align: left;
    }

    &.next {
      align-items: flex-end;
      text-align: right;
      margin-left: auto;
    }

    &.disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
  }

  .nav-label {
    font-size: 14px;
    color: var(--color-blue);
    font-weight: 500;
    margin-bottom: 4px;
    transition: color 0.5s;
  }

  .nav-title {
    font-size: 16px;
    color: var(--font-color-grey);
    font-weight: 600;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    transition: color 0.5s;
  }

  @media (max-width: 768px) {
    .nav-link {
      padding: 12px 16px;
    }

    .nav-label {
      font-size: 12px;
    }

    .nav-title {
      font-size: 14px;
    }
  }

  /**
   * Donation Section
   * -------------------------------------------------------------------------- */
  .donation-section {
    box-sizing: border-box;
    margin: 32px auto 0;
    max-width: 1200px;
  }

  .donation-container {
    padding: 24px;
    border-radius: 32px;
    border: 2px solid var(--foreground-color);
    background: var(--foreground-color);
    box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.8);
    text-align: center;
    transition:
      border-color 0.5s,
      background 0.5s,
      box-shadow 0.5s;
  }

  .donation-title {
    font-size: 16px;
    color: var(--font-color-grey);
    margin: 0 0 16px;
    transition: color 0.5s;
  }

  .donation-buttons {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .donation-item {
    position: relative;
  }

  .donation-btn {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 8px;
    border: none;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;

    &:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    &.wechat {
      background: #07c160;
      color: #fff;
    }

    &.alipay {
      background: #1677ff;
      color: #fff;
    }

    &.afdian {
      background: #946ce6;
      color: #fff;
    }
  }

  .donation-icon {
    width: 18px;
    height: 18px;
    margin-right: 6px;
  }

  .donation-qr {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) scale(0.95);
    opacity: 0;
    visibility: hidden;
    padding: 12px;
    border-radius: 12px;
    background: var(--foreground-color);
    border: 2px solid var(--foreground-color);
    box-shadow: 0px 4px 16px rgba(0, 0, 0, 0.15);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s ease;
    z-index: 100;

    img {
      width: 140px;
      height: 140px;
      border-radius: 8px;
      display: block;
    }

    &::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: var(--foreground-color);
    }
  }

  .donation-item:hover .donation-qr {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) scale(1);
  }

  @media (max-width: 768px) {
    .donation-container {
      padding: 20px;
    }

    .donation-title {
      font-size: 16px;
    }

    .donation-btn {
      padding: 8px 20px;
      font-size: 13px;
    }

    .donation-qr {
      img {
        width: 120px;
        height: 120px;
      }
    }
  }
</style>
