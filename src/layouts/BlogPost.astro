---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import WalineComment from "../components/WalineComment.astro";
import WalinePageView from "../components/WalinePageView.astro";
import PostFooter from "../components/PostFooter.astro";
import PhotoSwipe from "../components/PhotoSwipe.astro";
import TableOfContents from "../components/TableOfContents.astro";
import {
  FEATURE_READING_TIME,
  COMMENTS_ENABLE,
  COMMENTS_TYPE,
  SITE_TITLE,
} from "../consts";

type Props = CollectionEntry<"blog">["data"] & {
  minutesRead?: string;
  wordCount?: number;
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
  headings?: { depth: number; slug: string; text: string }[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  minutesRead,
  wordCount,
  prevPost,
  nextPost,
  enableDonation,
  enableNavigation,
  headings = [],
} = Astro.props;

// 是否启用 Waline 阅读量
const enableWalinePageView = COMMENTS_ENABLE && COMMENTS_TYPE === "waline";
---

<BaseLayout
  title={`${title} | ${SITE_TITLE}`}
  description={description}
  isPost={true}
  coverImage={heroImage}
>
  <!-- Banner内容 - 文章标题信息 -->
  <div slot="banner-content" class="post-banner">
    <h1 class="title">{title}</h1>
    <span class="status">
      {
        pubDate
          ? [
              pubDate && (
                <>
                  发布于 <FormattedDate date={pubDate} />
                </>
              ),
              updatedDate && (
                <>
                  更新于 <FormattedDate date={updatedDate} />
                </>
              ),
              FEATURE_READING_TIME && wordCount && <>约 {wordCount} 字</>,
              FEATURE_READING_TIME && minutesRead && <>{minutesRead}</>,
            ]
              .filter(Boolean)
              .map((item, index, arr) => (
                <>
                  {item}
                  {index < arr.length - 1 && " | "}
                </>
              ))
          : description
            ? description
            : null
      }
      {enableWalinePageView && <WalinePageView />}
    </span>
  </div>

  <!-- 主内容区域 - 包含 TOC 和文章 -->
  <div
    class={`post-layout ${!headings.some((h) => h.depth >= 2 && h.depth <= 3) ? "no-toc" : ""}`}
  >
    <!-- 主内容 - 文章内容 -->
    <article class="view-box">
      <div class="content">
        <slot />
      </div>
    </article>
    <!-- 右侧目录（桌面端） -->
    {headings.some((h) => h.depth >= 2 && h.depth <= 3) && (
      <aside class="toc-sidebar">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>

  <!-- 捐赠和翻页导航 -->
  <PostFooter
    prevPost={prevPost}
    nextPost={nextPost}
    enableDonation={enableDonation}
    enableNavigation={enableNavigation}
  />

  <!-- 评论区 -->
  <WalineComment />

  <!-- 图片灯箱 -->
  <PhotoSwipe />

  <!-- 移动端 TOC（放在 fixed-elements slot 中，确保 z-index 生效） -->
  {headings.some((h) => h.depth >= 2 && h.depth <= 3) && (
    <TableOfContents headings={headings} mobileOnly slot="fixed-elements" />
  )}
</BaseLayout>

<style lang="less" is:global>
  .post-banner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: var(--post-InnerBanner-color);
    text-shadow: 0 0 5px rgba(0, 0, 0, 0.8);
    z-index: 100;
    transition: color 0.5s;
    padding: 0 20px;

    .title {
      font-size: max(64px, 4.5vw);
      margin-bottom: 50px;
      text-align: center;
      margin-top: 0;
      color: var(--post-InnerBanner-color);
      transition: color 0.5s;
      word-break: break-word;
      overflow-wrap: break-word;
      max-width: 100%;
    }

    .status {
      font-size: max(20px, 1vw);
      font-weight: bold;
      color: var(--post-InnerBanner-color);
      transition: color 0.5s;
      text-align: center;
      word-break: break-word;
      overflow-wrap: break-word;
      max-width: 100%;
      line-height: 1.6;
    }

    @media (max-width: 768px) {
      padding: 0 16px;

      .title {
        font-size: clamp(28px, 6vw, 5vh);
        margin-bottom: 24px;
      }
      .status {
        font-size: clamp(14px, 3vw, 1.5vh);
      }
    }
  }

  .post-layout {
    display: flex;
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .toc-sidebar {
    flex-shrink: 0;
    width: 260px;
    position: relative;
  }

  .view-box {
    box-sizing: border-box;
    flex: 1;
    min-width: 0; // 允许 flex item 收缩到小于内容宽度
    position: relative;
    padding: 36px;
    border-radius: 32px;
    border: solid 2px var(--foreground-color);
    background: var(--foreground-color);
    box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.8);
    transition:
      opacity 0.5s ease-out,
      transform 1s cubic-bezier(0.61, 0.15, 0.26, 1),
      border 0.5s,
      background 0.5s,
      box-shadow 0.5s;

    // 当 TOC 显示时，限制最大宽度
    max-width: calc(1200px - 260px - 24px);
  }

  // 没有 TOC 时的布局
  .post-layout.no-toc {
    .view-box {
      margin: 0 auto;
      max-width: 1200px;
    }
  }

  // 移动端适配
  @media (max-width: 1024px) {
    .toc-sidebar {
      display: none;
    }

    .view-box {
      margin: 0 auto;
      max-width: 1200px;
    }
  }

  .content {
    background-image:
      linear-gradient(90deg, rgba(159, 219, 252, 0.15) 3%, transparent 0),
      linear-gradient(1turn, rgba(159, 219, 252, 0.15) 3%, transparent 0);
    background-size: 20px 20px;
    background-position: 50%;
    html[theme="dark"] & {
      background-image:
        linear-gradient(90deg, rgba(207, 198, 254, 0.08) 3%, transparent 0),
        linear-gradient(1turn, rgba(207, 198, 254, 0.08) 3%, transparent 0);
    }

    /**
     * Paragraph and inline elements
     * -------------------------------------------------------------------------- */

    p,
    summary {
      margin: 16px 0;
    }

    p {
      line-height: 28px;
      color: var(--font-color-grey);
      transition: color 0.5s;
    }

    blockquote {
      margin: 16px 0;
      border-left: 3px solid #5cd3ff;
      padding-left: 16px;
      background-color: #5cd4ff25;
      border-radius: 8px;
      html[theme="dark"] & {
        background-color: rgba(157, 124, 216, 0.1);
        border-left: 3px solid #9d7cd8;
      }
    }

    blockquote > p {
      margin: 0;
      font-size: 16px;
    }

    a {
      font-weight: 500;
      color: var(--color-blue);
      text-decoration: underline;
      text-underline-offset: 2px;
      transition:
        color 0.25s,
        opacity 0.25s;
    }

    strong {
      font-weight: bold;
      color: var(--font-color-grey);
      transition: color 0.5s;
    }

    code {
      font-family: "JetBrains Mono", sans-serif;
      line-height: 0;
      border-radius: 3px;
      background-color: rgba(0, 0, 0, 0.05);
      padding: 2px 6px;
      color: var(--font-color-grey);
      transition:
        color 0.5s,
        background-color 0.5s;
      html[theme="dark"] & {
        background-color: rgba(255, 255, 255, 0.1);
      }
    }

    /**
     * Code Block
     * -------------------------------------------------------------------------- */

    pre {
      position: relative;
      background-color: #efefef;
      border: 1px solid var(--foreground-color);
      border-radius: 16px;
      box-shadow: 0px 0px 5px #c1c1c1;
      overflow: hidden;
      padding: 16px;
      margin: 16px 0;
      transition:
        background-color 0.5s,
        border-color 0.5s,
        box-shadow 0.5s;

      html[theme="dark"] & {
        background-color: #1f1f2c;
        border: 1px solid #383852;
        box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.3);
      }

      code {
        background-color: transparent;
        padding: 0;
        font-family: "JetBrains Mono", sans-serif;
        line-height: 1.6;
        color: var(--font-color-grey);

        html[theme="dark"] & {
          background-color: transparent;
        }
      }
    }

    /**
     * Headings
     * -------------------------------------------------------------------------- */

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      position: relative;
      font-weight: bold;
      outline: none;
      color: var(--font-color-grey);
      transition: color 0.5s;
    }

    h1 {
      letter-spacing: -0.02em;
      line-height: 40px;
      font-size: 28px;
    }

    h2 {
      margin: 48px 0 16px;
      border-top: 2px solid #ced4da;
      padding-top: 24px;
      letter-spacing: -0.02em;
      line-height: 32px;
      font-size: 24px;
      html[theme="dark"] & {
        border-top: 2px solid rgba(157, 124, 216, 0.3);
      }
    }

    h3 {
      margin: 32px 0 0;
      letter-spacing: -0.01em;
      line-height: 28px;
      font-size: 20px;
    }

    h4,
    h5,
    h6 {
      margin: 0;
      line-height: 24px;
      font-size: 16px;
    }

    /**
     * Decorational elements
     * -------------------------------------------------------------------------- */
    hr {
      border: 0;
      border-top: 2px dashed #ced4da;
      html[theme="dark"] & {
        border-top: 2px dashed rgba(157, 124, 216, 0.3);
      }
    }

    /**
     * Lists
     * -------------------------------------------------------------------------- */

    ul,
    ol {
      padding-left: 1.25rem;
      margin: 16px 0;
      color: var(--font-color-grey);
      transition: color 0.5s;
    }

    ul {
      list-style: disc;
    }

    ol {
      list-style: decimal;
    }

    li + li {
      margin-top: 8px;
    }

    li > ol,
    li > ul {
      margin: 8px 0 0;
    }

    /**
     * Table
     * -------------------------------------------------------------------------- */

    table {
      width: 100%;
      border-collapse: collapse;
      border: 2px solid #cad4d5;
      html[theme="dark"] & {
        border: 2px solid #383852;
      }
    }

    th,
    td {
      padding: 10px;
      text-align: center;
      border-bottom: 2px solid #cad4d5;
      transition:
        background-color 0.5s,
        color 0.5s,
        border-color 0.5s;
    }

    th {
      background-color: #e7f6fa;
      color: var(--btn-hover);
      html[theme="dark"] & {
        background-color: rgba(157, 124, 216, 0.1);
        color: #e0e0e6;
        border-bottom: 2px solid #383852;
      }
    }

    th:nth-child(odd) {
      background-color: #e0f0f2;
      html[theme="dark"] & {
        background-color: rgba(157, 124, 216, 0.15);
      }
    }

    td {
      background-color: #f7f7f6;
      color: #3c3e41;
      html[theme="dark"] & {
        background-color: rgba(31, 31, 44, 0.6);
        color: #c8c8dc;
        border-bottom: 2px solid #383852;
      }
    }

    td:nth-child(odd) {
      background-color: #ececeb;
      html[theme="dark"] & {
        background-color: rgba(31, 31, 44, 0.8);
      }
    }

    /**
     * Images
     * -------------------------------------------------------------------------- */
    img {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
    }

    /**
     * Custom Block
     * -------------------------------------------------------------------------- */

    .custom-block {
      transition:
        background-color 0.5s,
        border-color 0.5s,
        color 0.5s;

      &.tip,
      &.info,
      &.warning,
      &.danger {
        margin: 1rem 0;
        border-left: 0.35rem solid;
        padding: 0.1rem 1.5rem;
        overflow-x: auto;
        border-radius: 16px;
      }

      &.tip {
        background-color: #f1f6fa;
        border-color: #57b6f6;
        color: #005e86;

        html[theme="dark"] & {
          background-color: rgba(158, 124, 216, 0.18);
          border-color: #9e7cd8ae;
          color: #e0e0e6;
        }
      }

      &.info {
        background-color: #f3f5f7;
        border-color: var(--font-color-grey);

        html[theme="dark"] & {
          background-color: rgba(108, 182, 255, 0.161);
          border-color: #6cb6ffcf;
          color: #e0e0e6;

          .custom-block-title {
            color: #89c4ff;
          }
        }
      }

      &.warning {
        border-color: #e7c000;
        color: #6b5900;
        background-color: #fff7d0;

        html[theme="dark"] & {
          background-color: rgba(231, 192, 0, 0.1);
          color: #f0d87d;

          .custom-block-title {
            color: #e7c000;
          }
        }
      }

      &.danger {
        border-color: #d58d86;
        color: #4d0000;
        background-color: #ffe6e6;

        html[theme="dark"] & {
          background-color: rgba(213, 141, 134, 0.1);
          color: #ffc4c0;

          .custom-block-title {
            color: #ff9b93;
          }
        }
      }

      &.details {
        summary {
          font-weight: bold;
          cursor: pointer;
        }
        margin: 1rem 0;
        padding: 1rem;
        background-color: rgba(var(--blue-shadow-color), 0.05);
        border-radius: 16px;
        html[theme="dark"] & {
          background-color: rgba(157, 124, 216, 0.1);
        }
      }
    }
  }

  @media (max-width: 768px) {
    .view-box {
      padding: 24px;
      border-radius: 32px;
    }

    .post-layout {
      padding: 0 12px;
    }
  }

  @media (min-width: 768px) {
    .content {
      h1 {
        letter-spacing: -0.02em;
        line-height: 40px;
        font-size: 32px;
      }
    }
  }
</style>
